local.file_match "payment_logs" {
    path_targets = [{
        "__path__" = "/var/log/payment.log",
        "job"      = "payment_gateway",
        "env"      = "development",
    }]
}
loki.source.file "payment_scraper" {
    targets    = local.file_match.payment_logs.targets
    forward_to = [loki.write.local_loki.receiver]
}

loki.write "local_loki" {
    endpoint {
        url = "http://loki:3100/loki/api/v1/push"
    }
}